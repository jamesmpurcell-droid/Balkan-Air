@model BalkanAir.Domain.Entities.LegInstance
@{
    ViewData["Title"] = $"Flight #{Model.Id}";
}

<h2>Flight Details</h2>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Flight ID</dt>
            <dd class="col-sm-9">@Model.Id</dd>

            <dt class="col-sm-3">Departure</dt>
            <dd class="col-sm-9">@Model.DepartureDateTime.ToString("dd MMM yyyy HH:mm")</dd>

            <dt class="col-sm-3">Arrival</dt>
            <dd class="col-sm-9">@Model.ArrivalDateTime.ToString("dd MMM yyyy HH:mm")</dd>

            <dt class="col-sm-3">Duration</dt>
            <dd class="col-sm-9">@Model.Duration</dd>

            <dt class="col-sm-3">Price</dt>
            <dd class="col-sm-9">@Model.Price.ToString("C")</dd>
        </dl>
    </div>
</div>

<a asp-action="Index" class="btn btn-secondary mt-3">Back to Flights</a>
