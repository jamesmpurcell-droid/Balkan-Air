@model BalkanAir.Web.Models.BookingConfirmViewModel
@{
    ViewData["Title"] = "Confirm Booking";
}

<h2>Confirm Your Booking</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Flight Details</h5>
            </div>
            <div class="card-body">
                @if (ViewBag.Flight is BalkanAir.Domain.Entities.LegInstance flight)
                {
                    var origin = flight.FlightLeg?.Route?.Origin;
                    var dest = flight.FlightLeg?.Route?.Destination;
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Route</dt>
                        <dd class="col-sm-8"><strong>@(origin?.Abbreviation ?? "—") &rarr; @(dest?.Abbreviation ?? "—")</strong></dd>

                        <dt class="col-sm-4">From</dt>
                        <dd class="col-sm-8">@(origin?.Name ?? "Unknown")</dd>

                        <dt class="col-sm-4">To</dt>
                        <dd class="col-sm-8">@(dest?.Name ?? "Unknown")</dd>

                        <dt class="col-sm-4">Departure</dt>
                        <dd class="col-sm-8">@flight.DepartureDateTime.ToString("dd MMM yyyy HH:mm")</dd>

                        <dt class="col-sm-4">Arrival</dt>
                        <dd class="col-sm-8">@flight.ArrivalDateTime.ToString("dd MMM yyyy HH:mm")</dd>

                        <dt class="col-sm-4">Duration</dt>
                        <dd class="col-sm-8">@flight.Duration.ToString(@"h\h\ mm\m")</dd>

                        <dt class="col-sm-4">Price</dt>
                        <dd class="col-sm-8"><strong class="text-success">@(((decimal)ViewBag.FarePrice).ToString("C"))</strong></dd>
                    </dl>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Booking Details</h5>
            </div>
            <div class="card-body">
                <form asp-action="Confirm" method="post">
                    <input type="hidden" asp-for="LegInstanceId" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="TravelClassId" class="form-label">Travel Class</label>
                        <select asp-for="TravelClassId" asp-items="@(ViewBag.TravelClasses as SelectList)" class="form-select"></select>
                    </div>

                    <div class="row mb-3">
                        <div class="col">
                            <label asp-for="Row" class="form-label"></label>
                            <input asp-for="Row" class="form-control" type="number" min="1" max="99" />
                        </div>
                        <div class="col">
                            <label asp-for="SeatNumber" class="form-label"></label>
                            <input asp-for="SeatNumber" class="form-control" maxlength="1" placeholder="A-F" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-success w-100">Confirm Booking</button>
                </form>
            </div>
        </div>
    </div>
</div>
