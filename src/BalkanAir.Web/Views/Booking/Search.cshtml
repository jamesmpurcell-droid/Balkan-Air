@model BalkanAir.Web.Models.BookingSearchViewModel
@{
    ViewData["Title"] = "Search Flights";
}

<h2>Search Flights</h2>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Search" method="post">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label asp-for="DepartureAirportId" class="form-label"></label>
                    <select asp-for="DepartureAirportId" asp-items="@(ViewBag.Airports as SelectList)" class="form-select">
                        <option value="">-- Select --</option>
                    </select>
                    <span asp-validation-for="DepartureAirportId" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="DestinationAirportId" class="form-label"></label>
                    <select asp-for="DestinationAirportId" asp-items="@(ViewBag.Airports as SelectList)" class="form-select">
                        <option value="">-- Select --</option>
                    </select>
                    <span asp-validation-for="DestinationAirportId" class="text-danger"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="DepartureDate" class="form-label"></label>
                    <input asp-for="DepartureDate" class="form-control" />
                    <span asp-validation-for="DepartureDate" class="text-danger"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="Passengers" class="form-label"></label>
                    <input asp-for="Passengers" class="form-control" type="number" min="1" max="9" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Search</button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (ViewBag.SearchResults is IEnumerable<BalkanAir.Domain.Entities.LegInstance> results)
{
    <h4>Available Flights</h4>
    @if (!results.Any())
    {
        <div class="alert alert-info">No flights found for the selected criteria.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Route</th>
                        <th>Departure</th>
                        <th>Arrival</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var leg in results)
                    {
                        <tr>
                            <td>@leg.FlightLeg?.Route?.Origin?.Abbreviation &rarr; @leg.FlightLeg?.Route?.Destination?.Abbreviation</td>
                            <td>@leg.DepartureDateTime.ToString("dd MMM yyyy HH:mm")</td>
                            <td>@leg.ArrivalDateTime.ToString("dd MMM yyyy HH:mm")</td>
                            <td><span class="badge bg-success">Available</span></td>
                            <td>
                                <a asp-action="Confirm" asp-route-legInstanceId="@leg.Id" class="btn btn-sm btn-primary">Book</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}
