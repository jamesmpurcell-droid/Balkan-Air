@model IEnumerable<BalkanAir.Domain.Entities.Seat>
@{ ViewData["Title"] = "Manage Seats"; }

<h2>Seats Management</h2>
<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">Back to Dashboard</a>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>ID</th><th>Row</th><th>Number</th><th>Travel Class ID</th><th>Leg Instance</th><th>Deleted</th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.IsDeleted ? "table-danger" : "")">
                    <td>@item.Id</td>
                    <td>@item.Row</td>
                    <td>@item.Number</td>
                    <td>@item.TravelClassId</td>
                    <td>@item.LegInstanceId</td>
                    <td>@item.IsDeleted</td>
                </tr>
            }
        </tbody>
    </table>
</div>
