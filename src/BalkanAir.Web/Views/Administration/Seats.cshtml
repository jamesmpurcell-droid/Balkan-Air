@model IEnumerable<BalkanAir.Domain.Entities.Seat>
@{ ViewData["Title"] = "Manage Seats"; }

<h2>Seats Management</h2>
<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Dashboard</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>ID</th><th>Row</th><th>Number</th><th>Travel Class</th><th>Flight</th><th>Reserved</th><th>Deleted</th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.IsDeleted ? "table-danger" : "")">
                    <td>@item.Id</td>
                    <td>@item.Row</td>
                    <td>@item.Number</td>
                    <td>@(item.TravelClassId)</td>
                    <td>@(item.LegInstance?.FlightLeg?.Flight?.Number ?? "—")</td>
                    <td>@(item.IsReserved ? "Yes" : "No")</td>
                    <td>@item.IsDeleted</td>
                </tr>
            }
        </tbody>
    </table>
</div>
