@model IEnumerable<BalkanAir.Domain.Entities.TravelClass>
@{ ViewData["Title"] = "Manage Travel Classes"; }

<h2>Travel Classes Management</h2>
<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Dashboard</a>
    <a asp-action="CreateTravelClass" class="btn btn-success btn-sm">+ Add Travel Class</a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show">@msg<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>ID</th><th>Type</th><th>Aircraft</th><th>Price</th><th>Rows</th><th>Seats</th><th>Meal</th><th>Deleted</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.IsDeleted ? "table-danger" : "")">
                    <td>@item.Id</td>
                    <td>@item.Type</td>
                    <td>@(item.Aircraft?.AircraftManufacturer?.Name) @(item.Aircraft?.Model)</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>@item.NumberOfRows</td>
                    <td>@item.NumberOfSeats</td>
                    <td>@item.Meal</td>
                    <td>@item.IsDeleted</td>
                    <td>
                        @if (!item.IsDeleted)
                        {
                            <a asp-action="EditTravelClass" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <form asp-action="DeleteTravelClass" asp-route-id="@item.Id" method="post" class="d-inline ms-1">
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this travel class?')">Delete</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
