@model IEnumerable<BalkanAir.Domain.Entities.TravelClass>
@{ ViewData["Title"] = "Manage Travel Classes"; }

<h2>Travel Classes Management</h2>
<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">Back to Dashboard</a>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>ID</th><th>Type</th><th>Price</th><th>Rows</th><th>Seats</th><th>Deleted</th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.IsDeleted ? "table-danger" : "")">
                    <td>@item.Id</td>
                    <td>@item.Type</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>@item.NumberOfRows</td>
                    <td>@item.NumberOfSeats</td>
                    <td>@item.IsDeleted</td>
                </tr>
            }
        </tbody>
    </table>
</div>
