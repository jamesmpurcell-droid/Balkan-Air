@model IEnumerable<BalkanAir.Domain.Entities.AircraftManufacturer>
@{ ViewData["Title"] = "Manage Manufacturers"; }

<h2>Aircraft Manufacturers</h2>
<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Dashboard</a>
    <a asp-action="CreateManufacturer" class="btn btn-success btn-sm">+ Add Manufacturer</a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show">@msg<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>ID</th><th>Name</th><th>Aircraft Count</th><th>Deleted</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.IsDeleted ? "table-danger" : "")">
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>@item.Aircrafts.Count(a => !a.IsDeleted)</td>
                    <td>@item.IsDeleted</td>
                    <td>
                        @if (!item.IsDeleted)
                        {
                            <a asp-action="EditManufacturer" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <form asp-action="DeleteManufacturer" asp-route-id="@item.Id" method="post" class="d-inline ms-1">
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this manufacturer?')">Delete</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
