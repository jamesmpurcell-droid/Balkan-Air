@model IEnumerable<BalkanAir.Domain.Entities.Route>
@{ ViewData["Title"] = "Manage Routes"; }

<h2>Routes Management</h2>
<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Dashboard</a>
    <a asp-action="CreateRoute" class="btn btn-success btn-sm">+ Add Route</a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show">@msg<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>ID</th><th>Origin</th><th>Destination</th><th>Distance (km)</th><th>Deleted</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.IsDeleted ? "table-danger" : "")">
                    <td>@item.Id</td>
                    <td>@item.Origin?.Name (@item.Origin?.Abbreviation)</td>
                    <td>@item.Destination?.Name (@item.Destination?.Abbreviation)</td>
                    <td>@item.DistanceInKm.ToString("N0")</td>
                    <td>@item.IsDeleted</td>
                    <td>
                        <a asp-action="EditRoute" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
