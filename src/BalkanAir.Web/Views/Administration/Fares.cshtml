@model IEnumerable<BalkanAir.Domain.Entities.Fare>
@{ ViewData["Title"] = "Manage Fares"; }

<h2>Fares Management</h2>
<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Dashboard</a>
    <a asp-action="CreateFare" class="btn btn-success btn-sm">+ Add Fare</a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show">@msg<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>ID</th><th>Route</th><th>Price</th><th>Deleted</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.IsDeleted ? "table-danger" : "")">
                    <td>@item.Id</td>
                    <td>@(item.Route?.Origin?.Abbreviation ?? "?") &rarr; @(item.Route?.Destination?.Abbreviation ?? "?")</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>@item.IsDeleted</td>
                    <td>
                        @if (!item.IsDeleted)
                        {
                            <a asp-action="EditFare" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <form asp-action="DeleteFare" asp-route-id="@item.Id" method="post" class="d-inline ms-1">
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this fare?')">Delete</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
