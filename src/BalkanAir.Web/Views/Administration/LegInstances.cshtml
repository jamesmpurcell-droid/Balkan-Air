@model IEnumerable<BalkanAir.Domain.Entities.LegInstance>
@{ ViewData["Title"] = "Manage Leg Instances"; }

<h2>Leg Instances Management</h2>
<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">Back to Dashboard</a>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>ID</th><th>Departure</th><th>Arrival</th><th>Deleted</th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.IsDeleted ? "table-danger" : "")">
                    <td>@item.Id</td>
                    <td>@item.DepartureDateTime.ToString("dd MMM yyyy HH:mm")</td>
                    <td>@item.ArrivalDateTime.ToString("dd MMM yyyy HH:mm")</td>
                    <td>@item.IsDeleted</td>
                </tr>
            }
        </tbody>
    </table>
</div>
