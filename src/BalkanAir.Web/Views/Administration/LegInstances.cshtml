@model IEnumerable<BalkanAir.Domain.Entities.LegInstance>
@{ ViewData["Title"] = "Manage Leg Instances"; }

<h2>Leg Instances Management</h2>
<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Dashboard</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>ID</th><th>Flight</th><th>Route</th><th>Departure</th><th>Arrival</th><th>Price</th><th>Aircraft</th><th>Bookings</th><th>Deleted</th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.IsDeleted ? "table-danger" : "")">
                    <td>@item.Id</td>
                    <td><strong>@(item.FlightLeg?.Flight?.Number ?? "—")</strong></td>
                    <td>@(item.FlightLeg?.Route?.Origin?.Abbreviation ?? "?") &rarr; @(item.FlightLeg?.Route?.Destination?.Abbreviation ?? "?")</td>
                    <td>@item.DepartureDateTime.ToString("dd MMM yyyy HH:mm")</td>
                    <td>@item.ArrivalDateTime.ToString("dd MMM yyyy HH:mm")</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>@(item.Aircraft?.AircraftManufacturer?.Name) @(item.Aircraft?.Model)</td>
                    <td>@item.Bookings.Count(b => !b.IsDeleted)</td>
                    <td>@item.IsDeleted</td>
                </tr>
            }
        </tbody>
    </table>
</div>
