@model BalkanAir.Web.Models.Admin.FlightFormViewModel
@{ ViewData["Title"] = "Create Flight"; }

<h2>Create Flight</h2>
<a asp-action="Flights" class="btn btn-outline-secondary btn-sm mb-3">Back to Flights</a>

<div class="row">
    <div class="col-md-6">
        <form asp-action="CreateFlight" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Number" class="form-label"></label>
                <input asp-for="Number" class="form-control" placeholder="e.g. BA101" />
                <span asp-validation-for="Number" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Create</button>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
