@model IEnumerable<BalkanAir.Domain.Entities.Country>
@{ ViewData["Title"] = "Manage Countries"; }

<h2>Countries Management</h2>
<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Dashboard</a>
    <a asp-action="CreateCountry" class="btn btn-success btn-sm">+ Add Country</a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show">@msg<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr><th>ID</th><th>Name</th><th>Abbreviation</th><th>Deleted</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.IsDeleted ? "table-danger" : "")">
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>@item.Abbreviation</td>
                    <td>@item.IsDeleted</td>
                    <td>
                        <a asp-action="EditCountry" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
